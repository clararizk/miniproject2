<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="CENTER" spacing="18"
      xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.example.demoproject2.HomeController"
      style="-fx-background-color: linear-gradient(to bottom right, #eff6ff, #dbeafe);">

    <padding>
        <Insets top="35" right="35" bottom="35" left="35"/>
    </padding>

    <Label text="Employee Management System"
           style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: #1e3a8a;"/>

    <Label text="Select an entity to manage"
           style="-fx-font-size: 15px; -fx-text-fill: #475569;"/>

    <Label fx:id="lblWelcome"
           style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #0f172a;"/>

    <Button text="Manage Employees"
            onAction="#openEmployees"
            prefWidth="320"
            prefHeight="45"
            style="-fx-background-color: #2563eb; -fx-text-fill: white; -fx-font-size: 16px; -fx-font-weight: bold; -fx-background-radius: 12;"/>

    <Button text="Manage Products"
            onAction="#openProducts"
            prefWidth="320"
            prefHeight="45"
            style="-fx-background-color: #2563eb; -fx-text-fill: white; -fx-font-size: 16px; -fx-font-weight: bold; -fx-background-radius: 12;"/>

    <Button text="Manage Orders"
            onAction="#openOrders"
            prefWidth="320"
            prefHeight="45"
            style="-fx-background-color: #2563eb; -fx-text-fill: white; -fx-font-size: 16px; -fx-font-weight: bold; -fx-background-radius: 12;"/>

    <Button text="Manage Clients"
            onAction="#openClients"
            prefWidth="320"
            prefHeight="45"
            style="-fx-background-color: #2563eb; -fx-text-fill: white; -fx-font-size: 16px; -fx-font-weight: bold; -fx-background-radius: 12;"/>

    <Button text="Logout"
            onAction="#handleLogout"
            prefWidth="160"
            prefHeight="42"
            style="-fx-background-color: #dc2626; -fx-text-fill: white; -fx-font-size: 15px; -fx-font-weight: bold; -fx-background-radius: 12;"/>
</VBox>
