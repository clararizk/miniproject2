<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox spacing="14"
      xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.example.demoproject2.ClientController">

    <padding>
        <Insets top="20" right="20" bottom="20" left="20"/>
    </padding>

    <Label text="Clients Management"/>

    <TextField fx:id="tfSearch" promptText="Search client..."/>

    <TableView fx:id="clientTable" prefHeight="260">
        <columns>
            <TableColumn fx:id="colId" text="ID" prefWidth="70"/>
            <TableColumn fx:id="colName" text="Name" prefWidth="150"/>
            <TableColumn fx:id="colEmail" text="Email" prefWidth="180"/>
            <TableColumn fx:id="colPhone" text="Phone" prefWidth="120"/>
            <TableColumn fx:id="colAddress" text="Address" prefWidth="150"/>
        </columns>
    </TableView>

    <TextField fx:id="tfName" promptText="Client name"/>
    <TextField fx:id="tfEmail" promptText="Client email"/>
    <TextField fx:id="tfPhone" promptText="Client phone"/>
    <TextField fx:id="tfAddress" promptText="Client address"/>

    <HBox spacing="10">
        <Button fx:id="btnAdd" text="Add" onAction="#handleAdd"/>
        <Button fx:id="btnUpdate" text="Update" onAction="#handleUpdate"/>
        <Button fx:id="btnDelete" text="Delete" onAction="#handleDelete"/>
        <Button fx:id="btnClear" text="Clear" onAction="#handleClear"/>
        <Button text="Back Home" onAction="#goHome"/>
    </HBox>

    <Label fx:id="lblStatus"/>
</VBox>
