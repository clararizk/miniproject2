<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="CENTER" spacing="18"
      xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.example.demoproject2.LoginController"
      style="-fx-background-color: linear-gradient(to bottom right, #0f172a, #1e3a8a);">

    <padding>
        <Insets top="40" right="40" bottom="40" left="40"/>
    </padding>

    <Label text="Employee Management System"
           style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: white;"/>

    <Label text="Login to continue"
           style="-fx-font-size: 14px; -fx-text-fill: #dbeafe;"/>

    <TextField fx:id="tfUsername"
               promptText="Username"
               maxWidth="280"
               style="-fx-background-radius: 10; -fx-border-radius: 10; -fx-padding: 10; -fx-font-size: 14px;"/>

    <PasswordField fx:id="pfPassword"
                   promptText="Password"
                   maxWidth="280"
                   style="-fx-background-radius: 10; -fx-border-radius: 10; -fx-padding: 10; -fx-font-size: 14px;"/>

    <Button text="Login"
            onAction="#handleLogin"
            maxWidth="280"
            style="-fx-background-color: #2563eb; -fx-text-fill: white; -fx-font-size: 15px; -fx-font-weight: bold; -fx-background-radius: 12; -fx-padding: 10 20 10 20;"/>

    <Button text="Clear"
            onAction="#handleClear"
            maxWidth="280"
            style="-fx-background-color: #64748b; -fx-text-fill: white; -fx-font-size: 14px; -fx-font-weight: bold; -fx-background-radius: 12; -fx-padding: 10 20 10 20;"/>

    <Label fx:id="lblMessage"
           style="-fx-text-fill: #fca5a5; -fx-font-size: 13px; -fx-font-weight: bold;"/>
</VBox>